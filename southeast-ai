<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Southeast AI Assistant</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #eef2f7; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .chat-container { width: 450px; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border-top: 5px solid #004a99; }
        h2 { color: #004a99; text-align: center; margin-top: 0; }
        #chat-box { height: 400px; overflow-y: auto; border: 1px solid #eee; padding: 15px; margin-bottom: 15px; background: #fafafa; border-radius: 8px; font-size: 14px; }
        .input-area { display: flex; gap: 10px; }
        input { flex: 1; padding: 12px; border: 1px solid #ddd; border-radius: 5px; outline: none; }
        button { padding: 10px 20px; background: #004a99; color: white; border: none; border-radius: 5px; cursor: pointer; transition: 0.3s; }
        button:hover { background: #003366; }
        .ai-msg { background: #e3f2fd; padding: 8px 12px; border-radius: 10px; margin: 5px 0; color: #333; }
        .user-msg { background: #f1f1f1; padding: 8px 12px; border-radius: 10px; margin: 5px 0; text-align: right; color: #555; }
    </style>
</head>
<body>
    <div class="chat-container">
        <h2>Buffalo AI Asistan 🦬</h2>
        <div id="chat-box"></div>
        <div class="input-area">
            <input type="text" id="user-input" placeholder="Okul hakkında bir şey sor...">
            <button onclick="askAI()">Sor</button>
        </div>
    </div>

    <script>
        // DİKKAT: Buraya kendi API Key'ini eklemelisin (Ücretsiz deneme alabilirsin)
        const API_KEY = 'BURAYA_API_ANAHTARINI_YAZ'; 

        async function askAI() {
            const input = document.getElementById('user-input');
            const chatBox = document.getElementById('chat-box');
            const userText = input.value;
            if (!userText) return;

            chatBox.innerHTML += `<div class="user-msg"><b>Sen:</b> ${userText}</div>`;
            input.value = "";
            chatBox.scrollTop = chatBox.scrollHeight;

            try {
                const response = await fetch('https://openai.com', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${API_KEY}`
                    },
                    body: JSON.stringify({
                        model: "gpt-3.5-turbo",
                        messages: [
                            {role: "system", content: "Sen Southeast High School öğrencilerine yardım eden bir asistansın. Nazik ve motive edicisin."},
                            {role: "user", content: userText}
                        ]
                    })
                });

                const data = await response.json();
                const aiResponse = data.choices[0].message.content;
                chatBox.innerHTML += `<div class="ai-msg"><b>AI:</b> ${aiResponse}</div>`;
            } catch (error) {
                chatBox.innerHTML += `<div class="ai-msg" style="color:red;"><b>Hata:</b> Bağlantı kurulamadı. API anahtarını kontrol et!</div>`;
            }
            chatBox.scrollTop = chatBox.scrollHeight;
        }
    </script>
</body>
</html>
